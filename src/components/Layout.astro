---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "本周 NBER 工作论文",
  description = "每周 NBER Working Papers 中文导读",
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={base} aria-label="NBER Weekly">
          <img src={`${base}brand/sencium-icon-dark.png`} alt="" width="32" height="32" />
          <span>申椿 · NBER Weekly</span>
        </a>
        <nav class="header-nav" aria-label="主导航">
          <a class="header-link" href={`${base}wechat-editor/`}>公众号编辑器</a>
          <a class="header-link" href="https://github.com/fyapeng/nber" target="_blank" rel="noreferrer noopener">
            GitHub
          </a>
          <a class="header-link" href="https://www.nber.org/papers" target="_blank" rel="noreferrer noopener">
            NBER
          </a>
        </nav>
      </header>

      <slot />

      <footer class="site-footer">
        <p>论文信息来自 NBER，中文翻译由 Kimi API 自动生成，仅供快速浏览参考。</p>
      </footer>
    </div>
  </body>
</html>
